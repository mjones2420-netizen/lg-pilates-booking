# Copy this file to .env.test and fill in the TEST project values.
# DO NOT EVER put production credentials in here.
# .env.test itself is gitignored.

# Test Supabase project URL
TEST_SUPABASE_URL=https://ngzfhamjuviwfwuncrjo.supabase.co

# Test Supabase project ID — the safety check refuses to run if this is missing
# or matches the production project ID (mrlooyixnlxzcfmvnqme)
TEST_SUPABASE_PROJECT_ID=ngzfhamjuviwfwuncrjo

# Test Supabase anon key (public, embedded in front-end — still gitignored as best practice)
TEST_SUPABASE_ANON_KEY=paste-anon-key-here

# URL of the deployed test-configured index.html.
# For local runs, point at a local file:// URL or a locally-served copy.
# In early-stage setup, leave blank and the tests will skip any that need a served page.
TEST_APP_URL=
